# start_all.ps1 전용 설정 — Electron 앱 자체(main.js/preload.js/renderer)는
# env 변수가 필요 없다. 앱 설정(BASE URL, 모델명, 워크스페이스 등)은 톱니바퀴
# 아이콘의 설정 창에서 관리되고 sessions.db(SQLite)에 저장된다.
#
# 이 파일을 .env로 복사하고 본인 환경에 맞게 값을 채운 뒤 start_all.ps1을 실행한다.

# llama.cpp 저장소(빌드된 llama-server가 들어있는 체크아웃) 경로
LLAMA_CPP_DIR=C:\path\to\llama.cpp

# 사용할 gguf 모델 파일 경로
MODEL_PATH=C:\path\to\model.gguf

# llama-server가 열 host/port. 이 컴퓨터에서만 쓸 거면 127.0.0.1 유지 권장
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080
